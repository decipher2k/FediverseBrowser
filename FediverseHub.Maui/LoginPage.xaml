<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FediverseHub.Maui.LoginPage"
             Title="{Binding Title}">
    <Grid Padding="24" RowDefinitions="*,Auto,*">
        <VerticalStackLayout Grid.Row="1" Spacing="16" MaximumWidthRequest="520">
            <Label Text="{Binding Title}"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
            <Label Text="{Binding Subtitle}"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />
            <Button Text="{Binding LoginLabel}" Clicked="OnLoginClicked" />
            <Button Text="{Binding RegisterLabel}" Clicked="OnRegisterClicked" />
            <Button Text="{Binding DemoModeLabel}" Clicked="OnSkipClicked" />
            <Label Text="{Binding SkipNotice}"
                   FontSize="12"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
