<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FediverseHub.Maui.SettingsPage"
             Title="{Binding Title}">
    <Grid Padding="16" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
        <Label Grid.Row="0" Text="{Binding Title}" FontSize="24" FontAttributes="Bold" />
        <VerticalStackLayout Grid.Row="1" Spacing="8">
            <Label Text="{Binding LanguageSectionTitle}" FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="8">
                <Switch IsToggled="{Binding Settings.UseSystemLanguage}" Toggled="OnUseSystemLanguageToggled" />
                <Label Text="{Binding UseSystemLanguageLabel}" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Languages}"
                        SelectionMode="Single"
                        SelectionChanged="OnLanguageSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,8"
                            Padding="10"
                            Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#374151}"
                            StrokeShape="RoundRectangle 8">
                        <VerticalStackLayout>
                            <Label Text="{Binding NativeName}" FontAttributes="Bold" />
                            <Label Text="{Binding EnglishName}" FontSize="12" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button Grid.Row="3"
                Text="{Binding LogoutLabel}"
                Clicked="OnLogoutClicked" />
    </Grid>
</ContentPage>
